# Turnout — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.

# ---------------------------------------------------------------
# Neon Postgres (https://neon.tech)
#
# DATABASE_URL uses the connection pooler endpoint (for runtime queries)
# DIRECT_URL uses the direct endpoint (required for Prisma migrations)
# Both strings are available in the Neon dashboard under "Connection Details"
# ---------------------------------------------------------------
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# ---------------------------------------------------------------
# OpenAI (https://platform.openai.com)
# Used by instagram-monitor.ts for event extraction with gpt-4o-mini
# ---------------------------------------------------------------
OPENAI_API_KEY="sk-..."

# ---------------------------------------------------------------
# Admin API protection
# Set this to a long, random string — used in x-admin-key header
# Generate one with: openssl rand -hex 32
# ---------------------------------------------------------------
ADMIN_SECRET_KEY="your-random-secret-here-change-this"

# ---------------------------------------------------------------
# Vercel Cron protection
# Set this in Vercel so scheduled monitor requests include a bearer token.
# Generate one with: openssl rand -hex 32
# ---------------------------------------------------------------
CRON_SECRET="your-random-cron-secret-here-change-this"
